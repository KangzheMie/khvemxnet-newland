# 操作系统生成的文件
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE / 编辑器配置文件 (根据你的使用情况选择)
.idea/
.vscode/
*.swp
*.swo

# Node.js 依赖目录
# 忽略根目录和前端目录下的 node_modules
node_modules/
frontend/node_modules/
# backend/node_modules/ 应该由 backend/.gitignore 忽略

# 构建产物 / 输出目录
# 假设前端构建产物在 dist 或 build 目录
frontend/dist/
frontend/build/
# 后端的构建产物应该由 backend/.gitignore 忽略

# 日志文件
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量文件 (通常包含敏感信息)
.env
.env.*
# 保留 .env.example 文件，作为配置示例
!.env.example

# 自动生成的文件
project_structure.txt

# 备份目录 (如果不需要版本控制)
backup/

# 临时文件
*.tmp

# 测试覆盖率报告
coverage/